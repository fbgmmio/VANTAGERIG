# Required: Google Apps Script deployment URL for email collection
APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# Required: password for the /admin panel
# Visit /admin with any username and this password
ADMIN_SECRET=change-me-to-a-strong-password

# Optional: POST a Slack/Discord/custom webhook when a new email is added
# Slack: https://hooks.slack.com/services/...
# Discord: append /slack to a Discord webhook URL
NOTIFY_WEBHOOK_URL=
